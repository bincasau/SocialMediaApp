      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.expect(pm.response.code).to.equal(200);",
              "});",
              "const data = pm.response.json();",
              "pm.test('API is healthy', function () {",
              "  pm.expect(data.ok).to.eql(true);",
              "});"
            ]
          }
        }
      ]
