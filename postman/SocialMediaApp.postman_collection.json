{
  "info": {
    "_postman_id": "7b0d2c9f-8df5-4b18-9b55-7c2d9c4f0b01",
    "name": "SocialMediaApp",
    "description": "Postman collection for the Django social media app. The app uses Django session auth and CSRF protection, so run the GET form requests first to capture the csrftoken cookie.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "csrf_token",
      "value": ""
    },
    {
      "key": "username",
      "value": "alice"
    },
    {
      "key": "email",
      "value": "alice@example.com"
    },
    {
      "key": "password",
      "value": "password123"
    },
    {
      "key": "password2",
      "value": "password123"
    },
    {
      "key": "post_id",
      "value": ""
    },
    {
      "key": "comment_body",
      "value": "Postman comment"
    },
    {
      "key": "follower",
      "value": "bob"
    },
    {
      "key": "follow_target",
      "value": "alice"
    },
    {
      "key": "recipient",
      "value": "alice"
    },
    {
      "key": "message_body",
      "value": "Hello from Postman"
    },
    {
      "key": "search_query",
      "value": "ali"
    },
    {
      "key": "profile_username",
      "value": "alice"
    },
    {
      "key": "chat_username",
      "value": "alice"
    }
  ],
  "item": [
    {
      "name": "01 - GET Signup Page",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/signup"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.expect(pm.response.code).to.equal(200);",
              "});",
              "",
              "const csrf = pm.cookies.get('csrftoken');",
              "pm.test('CSRF cookie exists', function () {",
              "  pm.expect(csrf).to.be.ok;",
              "});",
              "if (csrf) {",
              "  pm.environment.set('csrf_token', csrf);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - POST Signup",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-CSRFToken",
            "value": "{{csrf_token}}"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "username",
              "value": "{{username}}"
            },
            {
              "key": "email",
              "value": "{{email}}"
            },
            {
              "key": "password",
              "value": "{{password}}"
            },
            {
              "key": "password2",
              "value": "{{password2}}"
            }
          ]
        },
        "url": "{{base_url}}/signup"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const csrf = pm.cookies.get('csrftoken');",
              "if (csrf) {",
              "  pm.environment.set('csrf_token', csrf);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Response code is successful', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 302, 303]);",
              "});",
              "",
              "pm.test('Session cookie may exist after signup', function () {",
              "  const session = pm.cookies.get('sessionid');",
              "  pm.expect(session || true).to.be.ok;",
              "});"
            ]
          }
        }
      ]
    },
    {
