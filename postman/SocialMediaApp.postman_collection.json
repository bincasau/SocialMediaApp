    {
      "name": "02 - Register New User",
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{register_username}}\",\n  \"email\": \"{{register_email}}\",\n  \"password\": \"{{register_password}}\",\n  \"password2\": \"{{register_password}}\"\n}"
        },
        "url": "{{base_url}}/api/auth/register/"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const unique = 'postman_' + Date.now();",
              "pm.environment.set('register_username', unique);",
              "pm.environment.set('register_email', unique + '@example.com');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.expect(pm.response.code).to.equal(201);",
              "});",
              "const data = pm.response.json();",
              "pm.test('Register returns user and profile', function () {",
              "  pm.expect(data.ok).to.eql(true);",
              "  pm.expect(data.user.username).to.eql(pm.variables.get('register_username'));",
              "  pm.expect(data.profile).to.be.an('object');",
              "});"
            ]
          }
        }
      ]
    },
