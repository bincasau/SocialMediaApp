    {
      "name": "15 - Create Post With Image",
      "request": {
        "description": "Creates a post with multipart/form-data. If Postman cannot resolve the variable path, select a local image file for image_upload before sending.",
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "{{username}}",
              "type": "string"
            },
            {
              "key": "password",
              "value": "{{password}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "caption",
              "value": "{{post_caption}}",
              "type": "text"
            },
            {
              "key": "image_upload",
              "type": "file",
              "src": "{{post_image_path}}"
            }
          ]
        },
        "url": "{{base_url}}/api/posts/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.expect(pm.response.code).to.equal(201);",
              "});",
              "const data = pm.response.json();",
              "pm.test('Post is created with image', function () {",
              "  pm.expect(data.ok).to.eql(true);",
              "  pm.expect(data.post).to.be.an('object');",
              "  pm.expect(data.post.id).to.be.a('string');",
              "  pm.expect(data.post.caption).to.eql(pm.variables.get('post_caption'));",
              "  pm.expect(data.post.image).to.be.a('string');",
              "});",
              "if (data.post && data.post.id) {",
              "  pm.environment.set('post_id', data.post.id);",
              "}"
            ]
          }
        }
      ]
    },
